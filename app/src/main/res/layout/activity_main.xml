<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <!-- TITLE -->
    <TextView
        android:id="@+id/appTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Accident Detection System"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#0F172A"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp"/>

    <!-- STATUS CARD -->
    <LinearLayout
        android:id="@+id/statusCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_bg_light"
        android:padding="20dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/appTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Status"
            android:textSize="14sp"
            android:textColor="#64748B"/>

        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Monitoring for accidents..."
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#16A34A"
            android:layout_marginTop="6dp"/>

    </LinearLayout>

    <!-- SPEED CARD -->
    <LinearLayout
        android:id="@+id/speedCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_bg_light"
        android:padding="20dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/statusCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Current Speed"
            android:textSize="14sp"
            android:textColor="#64748B"/>

        <TextView
            android:id="@+id/speedText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 km/h"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="#0F172A"
            android:layout_marginTop="6dp"/>

    </LinearLayout>

    <!-- BUTTON CONTAINER (BOTTOM FIXED) -->
    <LinearLayout
        android:id="@+id/buttonContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- TRIGGER ACCIDENT -->
        <Button
            android:id="@+id/btnTestAccident"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text=" TRIGGER ACCIDENT"
            android:backgroundTintMode="src_in"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#EF4444"
            android:layout_marginBottom="12dp"
            android:elevation="6dp"/>

        <!-- TEST SMS -->
        <Button
            android:id="@+id/btnTestSMS"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="✉️ TEST SMS"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2563EB"
            android:elevation="6dp"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>